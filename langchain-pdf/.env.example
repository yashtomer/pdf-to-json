# Copy this file to `.env` and fill in your key.  cp .env.example .env

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=            # <-- paste your key here (sk-ant-...)
ANTHROPIC_MODEL=claude-sonnet-4-6   # sonnet = best accuracy/cost. haiku = cheapest: claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT=180         # seconds; multi-page PDFs can take a while

# --- PDF rendering ---
PDF_DPI=150                   # higher = sharper but more tokens; 150 is a good default
MAX_PAGES=25                  # safety cap on pages sent per document
IMAGE_MAX_EDGE=1568           # cap long edge in px; lower = cheaper, slight accuracy risk

# --- Cost controls ---
ENABLE_PROMPT_CACHE=true      # cache the static system prompt (helps once prompt is large)

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8001
