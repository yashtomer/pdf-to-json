# Copy this file to `.env` and fill in your key:  cp .env.example .env
# IMPORTANT: keep values clean — no inline "# comment" after a value, or the
# parser will treat the comment text as part of the value.

# --- Anthropic (Claude) ---
# Paste your key (sk-ant-...) after the = with nothing else on the line.
ANTHROPIC_API_KEY=
# Model: claude-sonnet-4-6 (accurate) or claude-haiku-4-5-20251001 (cheapest)
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT=180
# 0 = deterministic + most accurate for extraction (recommended). Leave at 0.
ANTHROPIC_TEMPERATURE=0

# --- PDF rendering ---
# Higher DPI = sharper but more tokens; 150 is a good default.
PDF_DPI=150
# Safety cap on pages sent per document.
MAX_PAGES=25
# Scanned work orders only: run the extraction N times and majority-vote the
# fields to absorb OCR variance on degraded digits. 1 = off (single pass).
WORKORDER_SCAN_RUNS=3
# Cap the image long edge (px); lower = cheaper, slight accuracy risk.
IMAGE_MAX_EDGE=1568

# --- Cost controls ---
# Cache the static system prompt (helps once the prompt is large).
ENABLE_PROMPT_CACHE=true

# --- Google Gemini (for /extract-grouped-gemini and /extract-workorder-gemini) ---
# Free key (no card) at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Groq (for /extract-form11-groq) ---
# Free key at https://console.groq.com/keys . Default model is a vision-capable
# Llama 4 (required to read scanned forms); keep the meta-llama/llama-4-* family.
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Local LLM (Ollama) for /extract-workorder-with-local-llm ---
# In Docker the host's Ollama is reached via host.docker.internal (default).
# For native local dev, set OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT=900

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8001

# --- Auth ---
# Comma-separated API keys accepted on /extract-grouped (sent as X-API-Key header).
# Empty = auth DISABLED (open). Generate a strong key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_KEYS=
